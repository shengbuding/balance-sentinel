<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".DeepSeekApp"
        android:allowBackup="false"
        android:networkSecurityConfig="@xml/network_security_config"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.DeepSeekBalance">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.DeepSeekBalance">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".widget.WidgetConfigActivity"
            android:exported="true"
            android:theme="@style/Theme.DeepSeekBalance">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <receiver android:name=".widget.StaticWidgetProvider_2x1" android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.balancesentinel.app.WIDGET_REFRESH" />
            </intent-filter>
            <meta-data android:name="android.appwidget.provider"
                android:resource="@xml/static_widget_info_2x1" />
        </receiver>

        <receiver android:name=".widget.StaticWidgetProvider_2x2" android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.balancesentinel.app.WIDGET_REFRESH" />
            </intent-filter>
            <meta-data android:name="android.appwidget.provider"
                android:resource="@xml/static_widget_info_2x2" />
        </receiver>

        <receiver android:name=".widget.StaticWidgetProvider_3x1" android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.balancesentinel.app.WIDGET_REFRESH" />
            </intent-filter>
            <meta-data android:name="android.appwidget.provider"
                android:resource="@xml/static_widget_info_3x1" />
        </receiver>

        <receiver android:name=".widget.StaticWidgetProvider_4x2" android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.balancesentinel.app.WIDGET_REFRESH" />
            </intent-filter>
            <meta-data android:name="android.appwidget.provider"
                android:resource="@xml/static_widget_info_4x2" />
        </receiver>

        <receiver android:name=".widget.StaticWidgetProvider_5x1" android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.balancesentinel.app.WIDGET_REFRESH" />
            </intent-filter>
            <meta-data android:name="android.appwidget.provider"
                android:resource="@xml/static_widget_info_5x1" />
        </receiver>

        <service
            android:name=".service.BalanceRefreshService"
            android:exported="false"
            android:foregroundServiceType="dataSync"
            android:stopWithTask="false" />

        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".receiver.KeepAliveReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.balancesentinel.app.KEEPALIVE_PING" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".receiver.MidnightReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.balancesentinel.app.MIDNIGHT_AGGREGATE" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".receiver.SnoozeReceiver"
            android:exported="false" />

    </application>

</manifest>
